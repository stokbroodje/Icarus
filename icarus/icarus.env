# Icarus environment
# sim.py / the loader read these from os.environ. Nothing auto-loads this file, so:
#   manual run:   set -a && source icarus.env && set +a && python -m icarus.testing.sim
#   systemd unit: EnvironmentFile=/home/katana/icarus/icarus.env
# Relative paths resolve from the current working directory (repo root for a manual run;
# use absolute paths under systemd, which has its own WorkingDirectory).

# franchise BAG export -> the address index is built from this
ICARUS_ADDR_CSV=data/adressen.csv

# directory of capture frames to replay through the pipeline
ICARUS_FRAMES=data/frames/*.png

# optional: restrict the index to delivery towns (comma-separated). Shrinks the street
# list, so street fuzzy-matching is much faster. Leave unset to load the whole province.
ICARUS_WOONPLAATS="Groningen,Haren Gn"

# only needed if tesserocr can't find the nld traineddata on its own (usually auto-detected
# on Debian). Point at the dir that contains nld.traineddata.
# TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata
